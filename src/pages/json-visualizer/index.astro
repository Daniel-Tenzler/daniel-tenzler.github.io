---
import JsonVisualizer from 'src/components/jsx/jsonVisualizer/JsonVisualizer';
import ToolPageLayout from 'src/layouts/ToolPageLayout.astro';
import { getToolByPath } from 'src/data/tools/tools';

const tool = getToolByPath('/json-visualizer');
---

<ToolPageLayout title={tool.title} description={tool.description}>
	<JsonVisualizer
		initialValue='{"name": "John Doe", "age": 30, "city": "New York"}'
		client:load
	/>
</ToolPageLayout>
