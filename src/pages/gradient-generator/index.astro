---
import { getToolByPath } from 'src/data/tools/tools';
import GradientGenerator from 'src/components/jsx/gradientGenerator/GradientGenerator';
import ToolPageLayout from 'src/layouts/ToolPageLayout.astro';

const tool = getToolByPath('/gradient-generator');
---

<ToolPageLayout title={tool.title} description={tool.description}>
	<GradientGenerator client:load />
</ToolPageLayout>
