---
import RedirectPage from 'src/components/astro/RedirectPage.astro';

const targetPath = '/imprint';
const canonicalUrl = new URL(targetPath, Astro.site).toString();
---

<RedirectPage
	targetPath={targetPath}
	canonicalUrl={canonicalUrl}
	title="Redirecting to Imprint"
	label="the imprint page"
/>
