---
const targetPath = '/imprint';
const canonicalUrl = 'https://daniel-tenzler.github.io/imprint';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width,initial-scale=1" />
		<meta http-equiv="refresh" content={`0; url=${targetPath}`} />
		<meta name="robots" content="noindex" />
		<link rel="canonical" href={canonicalUrl} />
		<title>Redirecting to Imprint</title>
	</head>
	<body>
		<p>
			Redirecting to <a href={targetPath}>the imprint page</a>.
		</p>
	</body>
</html>
