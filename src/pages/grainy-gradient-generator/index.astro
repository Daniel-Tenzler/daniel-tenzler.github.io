import { getToolByPath } from 'src/data/tools/tools';
import ToolPageLayout from 'src/layouts/ToolPageLayout.astro';

const tool = getToolByPath('/grainy-gradient-generator');
---

<ToolPageLayout title={tool.title} description={tool.description}>
	<GrainyGradientGenerator client:only="react" />
</ToolPageLayout>
