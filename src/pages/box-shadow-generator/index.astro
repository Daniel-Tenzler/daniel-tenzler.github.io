---
import BoxShadowGenerator from 'src/components/jsx/boxShadowGenerator/BoxShadowGenerator';
import { getToolByPath } from 'src/data/tools/tools';
import ToolPageLayout from 'src/layouts/ToolPageLayout.astro';

const tool = getToolByPath('/box-shadow-generator');
---

<ToolPageLayout title={tool.title} description={tool.description}>
	<BoxShadowGenerator client:load />
</ToolPageLayout>
