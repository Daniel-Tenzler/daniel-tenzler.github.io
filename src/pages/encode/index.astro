---
import { getToolByPath } from 'src/data/tools/tools';
import ToolPageLayout from 'src/layouts/ToolPageLayout.astro';
import UrlEncoder from 'src/components/jsx/urlEncoder/UrlEncoder';

const baseUrl = import.meta.env.BASE_URL || 'https://daniel-tenzler.github.io';
const tool = getToolByPath('/encode');
---

<ToolPageLayout title={tool.title} description={tool.description}>
	<UrlEncoder initialValue={baseUrl} client:load />
</ToolPageLayout>
