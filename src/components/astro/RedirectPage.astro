---
interface Props {
	targetPath: string;
	canonicalUrl: string;
	title: string;
	label: string;
}

const { targetPath, canonicalUrl, title, label } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width,initial-scale=1" />
		<meta http-equiv="refresh" content={`0; url=${targetPath}`} />
		<meta name="robots" content="noindex" />
		<link rel="canonical" href={canonicalUrl} />
		<title>{title}</title>
	</head>
	<body>
		<p>
			Redirecting to <a href={targetPath}>{label}</a>.
		</p>
	</body>
</html>
