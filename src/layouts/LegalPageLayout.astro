---
import GridBackground from 'src/components/jsx/gridBackground/GridBackground/GridBackground';
import ContentContainer from 'src/components/jsx/layouts/ContentContainer/ContentContainer';
import MainLayout from 'src/layouts/MainLayout.astro';

interface Props {
	title: string;
	description: string;
	showBackground?: boolean;
}

const { title, description, showBackground = false } = Astro.props;
---

<MainLayout title={title} description={description}>
	{showBackground && <GridBackground client:visible />}
	<ContentContainer>
		<slot />
	</ContentContainer>
</MainLayout>

<style is:global>
	:where(.privacy-content, .imprint-content) {
		width: 100%;
		max-width: 800px;
		margin: 0 auto;
		padding: 32px;
		background-color: var(--color-bg-tertiary);
		border-radius: 8px;
		box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
	}

	.imprint-detail {
		padding-left: 16px;
	}

	:where(.privacy-title, .imprint-title) {
		font-size: 36px;
		font-weight: 700;
		margin-bottom: 32px;
		color: var(--color-text-emphasis);
	}

	.privacy-title {
		text-align: center;
	}

	.imprint-title {
		margin-top: 0;
	}

	:where(.privacy-sections, .imprint-sections) {
		margin-top: 32px;
	}

	:where(.privacy-section, .imprint-section) {
		margin-bottom: 32px;
	}

	:where(.privacy-section-title, .imprint-section-title) {
		font-size: 24px;
		font-weight: 600;
		margin-bottom: 16px;
		color: var(--color-text-emphasis);
	}

	:where(.privacy-paragraph, .imprint-paragraph) {
		margin-bottom: 8px;
		color: var(--color-text-primary);
		line-height: 1.6;
	}

	:where(.privacy-content-section, .imprint-content-section) {
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.privacy-content-section {
		margin-bottom: 16px;
	}

	:where(.privacy-content-section, .imprint-content-section) span {
		color: var(--color-text-primary);
		line-height: 1.6;
	}

	.privacy-list {
		margin-bottom: 16px;
		padding-left: 24px;
		color: var(--color-text-primary);
		line-height: 1.6;
	}

	.privacy-list li {
		margin-bottom: 8px;
	}

	@media (max-width: 720px) {
		:where(.privacy-content, .imprint-content) {
			padding: 16px;
			width: 95%;
		}

		:where(.privacy-title, .imprint-title) {
			font-size: 30px;
		}
	}
</style>
