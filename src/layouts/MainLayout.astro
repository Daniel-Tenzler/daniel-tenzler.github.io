---
import AppShell from 'src/layouts/AppShell.astro';

interface Props {
	title: string;
	description?: string;
	structuredData?: object;
	canonicalUrl?: string;
	ogImage?: string;
}

const {
	title,
	description = "Daniel Tenzler's personal website and blog",
	structuredData,
	canonicalUrl,
	ogImage,
} = Astro.props;
---

<AppShell
	title={title}
	description={description}
	structuredData={structuredData}
	canonicalUrl={canonicalUrl}
	image={ogImage}
>
	<slot name="head" slot="head" />
	<slot />
</AppShell>
