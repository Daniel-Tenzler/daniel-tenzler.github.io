---
import AppShell from 'src/layouts/AppShell.astro';

interface Props {
	title: string;
	description?: string;
	structuredData?: object;
}

const {
	title,
	description = "Daniel Tenzler's personal website and blog",
	structuredData,
} = Astro.props;
---

<AppShell
	title={title}
	description={description}
	structuredData={structuredData}
	mainClass="portfolio-layout"
>
	<slot />
</AppShell>

<style is:global>
	/* Portfolio-specific layout overrides */
	body {
		line-height: 1.7;
	}

	main.portfolio-layout {
		width: 85%;
		max-width: calc(100% - 2em);
		margin: auto;
		padding: 1em 1em;
		min-height: calc(100vh - (201px + 32px));
		overflow: auto;
	}

	@media (max-width: 700px) {
		main.portfolio-layout {
			width: 90%;
			max-width: 90%;
		}
	}

	@media (max-width: 720px) {
		main.portfolio-layout {
			padding: 1em;
		}
	}
</style>
